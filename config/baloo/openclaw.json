{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789,
    "auth": {
      "mode": "token"
    },
    "controlUi": {
      "enabled": true
    }
  },
  "agents": {
    "defaults": {
      "skipBootstrap": true,
      "model": {
        "primary": "openai/gpt-5.5",
        "fallbacks": ["anthropic/claude-sonnet-4-6"]
      },
      "heartbeat": { "every": "0m" },
      "userTimezone": "Europe/Bucharest",
      "imageGenerationModel": {
        "primary": "openai/gpt-image-2",
        "timeoutMs": 180000
      }
    },
    "list": [
      {
        "id": "direct-message",
        "name": "Baloo",
        "default": true,
        "workspace": "/git/link/config/baloo/agents/direct-message",
        "heartbeat": {
          "every": "15m",
          "target": "whatsapp",
          "to": "${BALOO_OWNER_PHONE}",
          "isolatedSession": true
        },
        "tools": {
          "allow": [
            "web_fetch",
            "image",
            "image_generate",
            "searxng__*",
            "google-maps__*",
            "trek__*",
            "hass__*",
            "github-life__*",
            "cron",
            "k8s__*"
          ]
        }
      },
      {
        "id": "cooking",
        "name": "Baloo Shef",
        "workspace": "/git/link/config/baloo/agents/cooking",
        "tools": {
          "allow": [
            "web_fetch",
            "searxng__*",
            "github-life__*",
            "hass__*"
          ],
          "deny": [
            "trek__*",
            "google-maps__*",
            "image_generate",
            "k8s__*"
          ]
        }
      },
      {
        "id": "garden",
        "name": "Baloo Grădinar",
        "workspace": "/git/link/config/baloo/agents/garden",
        "heartbeat": {
          "every": "6h",
          "target": "whatsapp",
          "to": "${BALOO_GARDEN_GROUP}",
          "isolatedSession": true,
          "lightContext": true,
          "activeHours": { "start": "08:00", "end": "20:00" }
        },
        "tools": {
          "allow": [
            "web_fetch",
            "image",
            "image_generate",
            "searxng__*",
            "github-life__*",
            "hass__*"
          ],
          "deny": [
            "trek__*",
            "google-maps__*",
            "k8s__*"
          ]
        }
      },
      {
        "id": "trips",
        "name": "Baloo Trips",
        "workspace": "/git/link/config/baloo/agents/trips",
        "heartbeat": {
          "every": "3h",
          "target": "whatsapp",
          "to": "${BALOO_TRIPS_PALKOEK_GROUP}",
          "isolatedSession": true,
          "lightContext": true,
          "activeHours": { "start": "08:00", "end": "22:00" }
        },
        "tools": {
          "allow": [
            "trek__*",
            "searxng__*",
            "google-maps__*",
            "web_fetch",
            "image"
          ],
          "deny": [
            "hass__*",
            "github-life__*",
            "image_generate",
            "k8s__*"
          ]
        }
      },
      {
        "id": "main",
        "name": "Baloo Root",
        "workspace": "/git/link/config/baloo/agents/main",
        "tools": {
          "allow": [],
          "deny": [
            "hass__*",
            "github-life__*",
            "trek__*",
            "google-maps__*",
            "image_generate",
            "k8s__*"
          ]
        }
      }
    ]
  },
  "bindings": [
    {
      "agentId": "direct-message",
      "match": {
        "channel": "whatsapp",
        "peer": { "kind": "direct", "id": "${BALOO_OWNER_PHONE}" }
      }
    },
    {
      "agentId": "direct-message",
      "match": {
        "channel": "whatsapp",
        "peer": { "kind": "direct", "id": "${KINGA_PHONE}" }
      }
    },
    {
      "agentId": "cooking",
      "match": {
        "channel": "whatsapp",
        "peer": { "kind": "group", "id": "${BALOO_SHEF_GROUP}" }
      }
    },
    {
      "agentId": "garden",
      "match": {
        "channel": "whatsapp",
        "peer": { "kind": "group", "id": "${BALOO_GARDEN_GROUP}" }
      }
    },
    {
      "agentId": "trips",
      "match": {
        "channel": "whatsapp",
        "peer": { "kind": "group", "id": "${BALOO_TRIPS_PALKOEK_GROUP}" }
      }
    }
  ],
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": ["${BALOO_OWNER_PHONE}", "${KINGA_PHONE}"]
    }
  },
  "diagnostics": {
    "stuckSessionWarnMs": 60000,
    "stuckSessionAbortMs": 900000
  },
  "cron": { "enabled": true },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "plugins": {
    "allow": ["whatsapp"]
  },
  "mcp": {
    "sessionIdleTtlMs": 3600000,
    "servers": {
      "searxng": {
        "url": "http://mcp-searxng.baloo.svc.cluster.local:3000/mcp",
        "transport": "streamable-http"
      },
      "google-maps": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-google-maps"],
        "env": {
          "GOOGLE_MAPS_API_KEY": "${GOOGLE_MAPS_API_KEY}"
        }
      },
      "github-life": {
        "command": "node",
        "args": ["/git/link/config/baloo/tools/github-mcp-start.js"],
        "env": {
          "GITHUB_APP_ID": "${GITHUB_APP_ID}",
          "GITHUB_APP_INSTALLATION_ID": "${GITHUB_APP_INSTALLATION_ID}",
          "GITHUB_APP_PRIVATE_KEY_FILE": "/var/run/secrets/github-app/private-key.pem"
        }
      },
      "trek": {
        "command": "node",
        "args": ["/git/link/config/baloo/tools/trek-mcp-proxy.js"],
        "env": {
          "TREK_CLIENT_ID": "${TREK_CLIENT_ID}",
          "TREK_CLIENT_SECRET": "${TREK_CLIENT_SECRET}"
        }
      },
      "hass": {
        "url": "http://192.168.1.102:8123/mcp_server/sse",
        "transport": "sse",
        "headers": {
          "Authorization": "Bearer ${HA_TOKEN_READONLY}"
        }
      },
      "k8s": {
        "url": "http://mcp-k8s.baloo.svc.cluster.local:3000/mcp",
        "transport": "streamable-http"
      }
    }
  },
  "tools": {
    "media": {
      "audio": {
        "enabled": true,
        "echoTranscript": true,
        "echoFormat": "🎙️ \"{transcript}\"",
        "models": [
          {
            "type": "cli",
            "command": "python3",
            "args": ["/git/link/config/baloo/whisper-transcribe.py", "{{MediaPath}}"],
            "capabilities": ["audio"],
            "timeoutSeconds": 600
          }
        ]
      }
    }
  }
}
