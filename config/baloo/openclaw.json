{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789,
    "auth": {
      "mode": "token"
    },
    "controlUi": {
      "enabled": true
    }
  },
  "agents": {
    "defaults": {
      "skipBootstrap": true,
      "model": "anthropic/claude-sonnet-4-6",
      "heartbeat": { "every": "1h" }
    },
    "list": [
      {
        "id": "echo",
        "name": "Baloo",
        "workspace": "/git/link/config/baloo/agents/echo",
        "tools": {
          "allow": [
            "web_search",
            "web_fetch",
            "browser",
            "x_search",
            "image",
            "mcp__google-maps__*"
          ]
        }
      },
      {
        "id": "kinga",
        "name": "Baloo",
        "workspace": "/git/link/config/baloo/agents/kinga",
        "tools": {
          "allow": [
            "web_search",
            "web_fetch",
            "browser",
            "x_search",
            "image",
            "mcp__google-maps__*"
          ]
        }
      }
    ]
  },
  "bindings": [
    {
      "agentId": "echo",
      "match": {
        "channel": "whatsapp",
        "peer": { "kind": "direct", "id": "${BALOO_OWNER_PHONE}" }
      }
    },
    {
      "agentId": "kinga",
      "match": {
        "channel": "whatsapp",
        "peer": { "kind": "direct", "id": "${KINGA_PHONE}" }
      }
    }
  ],
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": ["${BALOO_OWNER_PHONE}", "${KINGA_PHONE}"]
    }
  },
  "cron": { "enabled": false },
  "plugins": {
    "allow": ["whatsapp"]
  },
  "mcp": {
    "servers": {
      "google-maps": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-google-maps"],
        "env": {
          "GOOGLE_MAPS_API_KEY": "${GOOGLE_MAPS_API_KEY}"
        }
      }
    }
  },
  "tools": {
    "media": {
      "audio": {
        "enabled": true,
        "echoTranscript": true,
        "echoFormat": "🎙️ \"{transcript}\"",
        "models": [
          {
            "type": "cli",
            "command": "python3",
            "args": ["/git/link/config/baloo/whisper-transcribe.py", "{{MediaPath}}"],
            "capabilities": ["audio"],
            "timeoutSeconds": 600
          }
        ]
      }
    }
  }
}
