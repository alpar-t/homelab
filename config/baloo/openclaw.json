{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789,
    "auth": {
      "mode": "token"
    },
    "controlUi": {
      "enabled": true
    }
  },
  "agents": {
    "defaults": {
      "skipBootstrap": true,
      "model": "anthropic/claude-sonnet-4-6",
      "heartbeat": { "every": "0m" }
    },
    "list": [
      {
        "id": "direct-message",
        "name": "Baloo",
        "workspace": "/git/link/config/baloo/agents/direct-message",
        "tools": {
          "allow": [
            "web_fetch",
            "browser",
            "image",
            "searxng__*",
            "google-maps__*",
            "trek__*",
            "hass__*",
            "github-life__*"
          ]
        }
      },
      {
        "id": "cooking",
        "name": "Baloo Shef",
        "workspace": "/git/link/config/baloo/agents/cooking",
        "tools": {
          "allow": [
            "web_fetch",
            "searxng__*",
            "github-life__*",
            "hass__*"
          ]
        }
      },
      {
        "id": "garden",
        "name": "Baloo Grădinar",
        "workspace": "/git/link/config/baloo/agents/garden",
        "tools": {
          "allow": [
            "web_fetch",
            "image",
            "searxng__*",
            "github-life__*",
            "hass__*"
          ]
        }
      }
    ]
  },
  "bindings": [
    {
      "agentId": "direct-message",
      "match": {
        "channel": "whatsapp",
        "peer": { "kind": "direct", "id": "${BALOO_OWNER_PHONE}" }
      }
    },
    {
      "agentId": "direct-message",
      "match": {
        "channel": "whatsapp",
        "peer": { "kind": "direct", "id": "${KINGA_PHONE}" }
      }
    },
    {
      "agentId": "cooking",
      "match": {
        "channel": "whatsapp",
        "peer": { "kind": "group", "id": "${BALOO_SHEF_GROUP}" }
      }
    },
    {
      "agentId": "garden",
      "match": {
        "channel": "whatsapp",
        "peer": { "kind": "group", "id": "${BALOO_GARDEN_GROUP}" }
      }
    }
  ],
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": ["${BALOO_OWNER_PHONE}", "${KINGA_PHONE}"]
    }
  },
  "diagnostics": {
    "stuckSessionWarnMs": 60000,
    "stuckSessionAbortMs": 900000
  },
  "cron": { "enabled": false },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "plugins": {
    "allow": ["whatsapp"]
  },
  "mcp": {
    "servers": {
      "searxng": {
        "url": "http://mcp-searxng.baloo.svc.cluster.local:3000/mcp",
        "transport": "streamable-http"
      },
      "google-maps": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-google-maps"],
        "env": {
          "GOOGLE_MAPS_API_KEY": "${GOOGLE_MAPS_API_KEY}"
        }
      },
      "github-life": {
        "command": "node",
        "args": ["/git/link/config/baloo/tools/github-mcp-start.js"],
        "env": {
          "GITHUB_APP_ID": "${GITHUB_APP_ID}",
          "GITHUB_APP_INSTALLATION_ID": "${GITHUB_APP_INSTALLATION_ID}",
          "GITHUB_APP_PRIVATE_KEY_FILE": "/var/run/secrets/github-app/private-key.pem"
        }
      },
      "trek": {
        "url": "https://travel.newjoy.ro/mcp",
        "transport": "streamable-http",
        "auth": "oauth"
      },
      "hass": {
        "url": "http://192.168.1.102:8123/mcp_server/sse",
        "transport": "sse",
        "headers": {
          "Authorization": "Bearer ${HA_TOKEN_READONLY}"
        }
      }
    }
  },
  "tools": {
    "media": {
      "audio": {
        "enabled": true,
        "echoTranscript": true,
        "echoFormat": "🎙️ \"{transcript}\"",
        "models": [
          {
            "type": "cli",
            "command": "python3",
            "args": ["/git/link/config/baloo/whisper-transcribe.py", "{{MediaPath}}"],
            "capabilities": ["audio"],
            "timeoutSeconds": 600
          }
        ]
      }
    }
  }
}
