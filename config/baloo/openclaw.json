{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789,
    "auth": {
      "mode": "token"
    },
    "controlUi": {
      "enabled": true
    }
  },
  "agents": {
    "defaults": {
      "skipBootstrap": true,
      "model": "anthropic/claude-sonnet-4-6",
      "heartbeat": { "every": "1h" }
    },
    "list": [
      {
        "id": "echo",
        "name": "Baloo",
        "workspace": "/git/link/config/baloo/agents/echo",
        "tools": {
          "deny": ["*"]
        }
      }
    ]
  },
  "bindings": [
    {
      "agentId": "echo",
      "match": {
        "channel": "whatsapp",
        "peer": { "kind": "direct", "id": "${BALOO_OWNER_PHONE}" }
      }
    }
  ],
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": ["${BALOO_OWNER_PHONE}"]
    }
  },
  "cron": { "enabled": false },
  "plugins": {
    "allow": ["@openclaw/whatsapp"]
  },
  "tools": {
    "media": {
      "audio": {
        "enabled": true,
        "echoTranscript": true,
        "echoFormat": "🎙️ \"{transcript}\"",
        "models": [
          {
            "type": "cli",
            "command": "python3",
            "args": ["/git/link/config/baloo/whisper-transcribe.py", "{{MediaPath}}"],
            "capabilities": ["audio"],
            "timeoutSeconds": 120
          }
        ]
      }
    }
  }
}
